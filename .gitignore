# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache/

# IDE / editor files
.vscode/
.idea/
*.iml

# OS files
.DS_Store
Thumbs.db

# Environment and local settings
.env
.env.*
!.env.example

# Local databases and SQLite runtime artifacts
*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal
*.db-wal
*.sqlite-wal
*.db-shm
*.sqlite-shm

# Logs and runtime artifacts
logs/
*.log
*.pid
*.tmp
*.temp
*.bak
*.swp
*.swo

# Local data directories
/data/generated/**
!/data/generated/.gitkeep

# Raw downloaded retailer files and large local inputs
/data/raw/**
!/data/raw/.gitkeep

# Keep deterministic sample data under version control
!/data/samples/**

# Test fixture artifacts
/tests/fixtures/tmp/
/tests/fixtures/generated/

# Jupyter
.ipynb_checkpoints/

# Optional project-specific files
local_settings.py

*:Zone.Identifier
